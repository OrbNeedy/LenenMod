WorldGen.Harujion: A dangerous youkai plant has appeared in the world.

SenriCopy: {
	Default: {
		OfudaName: Senri Ofuda
		Description: Shoot a fast ink bullet that leaves trails of bullets.
	}

	KingSlime: {
		OfudaName: King Slime Ofuda
		Description: Shoot a bullet that separates when hitting something.
	}

	EyeOfCthulhu: {
		OfudaName: Eye of Cthulhu Ofuda
		Description: Shoot two big bullets that dash towards an enemy.
	}

	EaterOfWorlds: {
		OfudaName: Eater of Worlds Ofuda
		Description:
			'''
			Shoot a long string of talismans that undulates 
			towards an enemy.
			'''
	}

	BrainOfCthulhu: {
		OfudaName: Brain of Cthulhu Ofuda
		Description: Bullets appear around the target when attacking.
	}

	QueenBee: {
		OfudaName: Queen Bee Ofuda
		Description: Shoot small but persistent bullets.
	}

	Skeletron: {
		OfudaName: Skeletron Ofuda
		Description: Shoots a fast moving wall of bullets.
	}

	Deerclops: {
		OfudaName: Deerclops Ofuda
		Description: Big Bullets appear to interrupt the enemy's path.
	}

	WallOfFlesh: {
		OfudaName: Wall of Flesh Ofuda
		Description:
			'''
			Shoots bullets that turn into knives and fly
			towards the enemy.
			'''
	}

	QueenSlime: {
		OfudaName: Queen Slime Ofuda
		Description: A bullet appears on top of the enemy and moves downwards.
	}

	Retinazer: {
		OfudaName: Retinazer Ofuda
		Description: Rains down bullets on the entire screen.
	}

	Spazmatism: {
		OfudaName: Spazmatism Ofuda
		Description: Shoots bullets with cursed flames.
	}

	Twins: {
		OfudaName: Twins Ofuda
		Description: ""
	}

	TheDestroyer: {
		OfudaName: Destroyer Ofuda
		Description:
			'''
			Shoot a long string of talismans that shoot 
			bullets at the enemy.
			'''
	}

	SkeletronPrime: {
		OfudaName: Skeletron Prime Ofuda
		Description: Shoots four slightly delayed projectiles.
	}

	Plantera: {
		OfudaName: Plantera Ofuda
		Description: Pollutes the battlefield with static bullets.
	}

	Golem: {
