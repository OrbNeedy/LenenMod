# This file will automatically update with entries for new content after a build and reload.

Emotes.NPCEmotes.Command: doortosomewhere

Items: {
	DimensionalFragment: {
		DisplayName: Dimensional Fragment
		Tooltip: Fragments from a different dimension you can throw.
	}

	UnstableRock: {
		DisplayName: Unstable Rock
		Tooltip: A strange rock that seems to affect the space around it.
	}

	DimensionalFracture: {
		DisplayName: Dimensional Fracture
		Tooltip:
			'''
			This is going to explode at any moment.
			Might want to throw it away before it does.
			'''
	}

	DimensionalOrbs: {
		DisplayName: Dimensional Orbs
		Tooltip:
			'''
			Orbs that follow their user and shoot fragments of other dimensions
			when commanded.
			Uses {0} mana for each two fragments shot.
			[SCCooldownMana]
			'''
	}

	BottleOpener: {
		DisplayName: Bottle Opener
		Tooltip: A simple bottle opener with no notable qualities to it.
	}

	SwordShapedBottleOpener: {
		DisplayName: Sword-shaped Bottle Opener
		Tooltip:
			'''
			A bottle opener in the shape of a sword.
			It could be used as a sword as well, if you want.
			The craftsmanship is amazing.
			'''
	}

	Tasouken: {
		DisplayName: Tasouken
		Tooltip:
			'''
			The legendary cloud-mowing sword, Tasouken, one of the imperial regalias.
			Cuts remotely at the mouse position.
			[SCCooldown]
			'''
	}

	AssassinKnife: {
		DisplayName: Throwing Knife
		Tooltip:
			'''
			A throwing knife made with amazing quality.
			Right click to throw additional knives every few seconds.
			'''
	}

	RustedKnife: {
		DisplayName: Rusty Knife
		Tooltip: Just a rusty knife, it's probably full of infections.
	}

	ImprovedKnife: {
		DisplayName: Colt Snake
		Tooltip:
			'''
			A set of knives made for an assassin.
			Right click to use Cut card "Slit Snake".
			Adds {0} Spell Card cooldown to the player.
			'''
	}

	AkaWing: {
		DisplayName: Fiery Wing
		Tooltip:
			'''
			A wing that protects the user against some Ice related debuffs.
			May be part of a greater whole.
			'''
	}

	HooakaWings: {
		DisplayName: Dual Wings
		Tooltip:
			'''
			Wings that protect the user against ice and fire related debuffs.
			Is the greater whole.
			'''
	}

	HooWing: {
		DisplayName: Icy Wing
		Tooltip:
			'''
			A wing that protects the user against some Fire related debuffs.
			May be part of a greater whole.
			'''
	}

	BrokenBirdDrone: {
		DisplayName: Broken Drone
		Tooltip:
			'''
			A broken drone in the shape of a bird.
			It's not a bird you can recognize.
			'''
	}

	FunctionalBirdDrone: {
		DisplayName: Repaired Drone
		Tooltip:
			'''
			A functional version of the drone that can now shoot.
			The mechanism is beyond your ability to fully repair.
			'''
	}

	TrueBirdDrone: {
		DisplayName: Upgraded Drone
		Tooltip:
			'''
			The drone you fixed is now completed, came with other 3 drones.
			Each drone shoots lasers in various directions.
			Right click to use RNA "Retrovirus".
			Adds {0} Spell Card cooldown to the player.
			'''
	}

	GashadokuroSkull: {
		DisplayName: Gashadokuro Skull
		Tooltip:
			'''
			A strangely large skull that works fine as a helmet.
			Gives the wearer a Skull Barrier, which reflects projectiles when hit.
			Cooldown is increased by 100% when the barrier is broken by a projectile.
			'''
	}

	BarrierPotion: {
		DisplayName: Barrier Potion
		Tooltip:
			'''
			Enhances the consumer's barriers, decreasing the time it 
			takes for them to recover.
			'''
	}

	MajorBarrierPotion: {
		DisplayName: Major Barrier Potion
		Tooltip:
			'''
			Enhances the consumer's barriers, greatly decreasing the time it 
			takes for them to recover.
			'''
	}

	MinorBarrierPotion: {
		DisplayName: Minor Barrier Potion
		Tooltip:
			'''
			Enhances the consumer's barriers, slightly decreasing the time it 
			takes for them to recover.
			'''
	}

	DesperateBarrierItem: {
		DisplayName: Desperate Barrier
		Tooltip:
			'''
			Gives the wearer a Desperate Barrier, which becomes more powerful when
			below 50% health, also increasing the power and cooldown of all Spell Cards.
			Also decreases damage taken under 50% health by {0}%.
			'''
	}

	RevivedGashadokuroSkull: {
		DisplayName: Revitalized Gashadokuro Skull
		Tooltip:
			'''
			A strangely large skull that works fine as a helmet.
			It was improved after absorbing the spirits you were carrying.
			Press the {$Keybinds.Revival.DisplayName} key to consume 
			spirits and enter an upgraded state that lasts for {0} seconds.
			The upgraded state increases base damage by {2}, multiplicative 
			damage by {1}% and armor penetration by {3}, but reduces damage 
			reduction by {4}% and defense by {5}.
			Gives the wearer an improved Skull Barrier, which resists more 
			hits and grants knockback resistance.
			'''
	}

	RiftDye: {
		DisplayName: Dimension Dye
		Tooltip: Lets you see the back side.
	}

	NoiseDye: {
		DisplayName: Trace Dye
		Tooltip: This is what you get for making so many mistakes.
	}

	MemoryKnife: {
		DisplayName: Aftermath Blade
		Tooltip:
			'''
			A knife that fluctuates between states.
			Press right click to change between them.
			'''
	}

	BarrierWeapon: {
		DisplayName: Tome of barriers Vol.3
		Tooltip:
			'''
			A tome detailing how to use barriers in a more offensive way.
			Right click to use "Prime Minister in Black Robes", spending {0} mana.
			Adds {1} Spell Card cooldown to the player.
			'''
	}

	HammerShapedBottleOpener: {
		DisplayName: Hamaxe-shaped Bottle Opener
		Tooltip:
			'''
			A bottle opener in the shape of a hammer.
			You can also cut trees with it if you want.
			'''
	}

	ExtendedGrab: {
		DisplayName: Grab Extension
		Tooltip:
			'''
			Summons a pair of hand-shaped Haniwa to act as your hands.
			Press left click to guide them to a location as they grab items 
			on the way.
			Press right click to grab friendly NPCs instead.
			Items will be released when they get close to you, NPCs will 
			be released when the hands start to return to your side.
			'''
	}

	HaniwaMaker: {
		DisplayName: Haniwa Caller
		Tooltip: Summons a Special Haniwa Artillery Unit.
	}

	SoulItem: {
		DisplayName: Spirit
		Tooltip:
			'''
			The spirit of a previously living being.
			It can power many things.
			'''
	}

	Harujion: {
		DisplayName: Harujion
		Tooltip:
			'''
			A beautiful flower that constantly absorbs the life around it.
			Since it was cut down, it can't do so any more, but you may still use 
			it's powers to resurrect yourself, if you give it enough spirits.
			Consumes 500 spirits to resurrect.
			Also attracts Spirit items.
			It will give you a barrier upon resurrection.
			'''
	}

	HarujionTracker: {
		DisplayName: Harujion Tracker
		Tooltip:
			'''
			An ingenious invension of yours.
			It locates and tells you the direction to the Harujion, if it exists.
			'''
	}

	SpiritVision: {
		DisplayName: Spirit Vision
		Tooltip:
			'''
			A visor that lets you see the spirits held by other living beings.
			It has the unintended side effect of allowing you to detect enemies.
			Hide the accessory to deactivate the spirit readings.
			'''
	}

	AntiGravityCape: {
		DisplayName: Anti Gravity Cape
		Tooltip:
			'''
			A stylish cape that gives the user a gravitational barrier.
			The barrier gives infinite flight and allows levitating from the ground.
			It also slows down falls and pushes enemies away from you.
			Press the Adjust Gravity key to deactivate levitation.
			'''
	}

	ClauseCape: {
		DisplayName: Clause Cape
		Tooltip:
			'''
			A festive cape that gives the user a jolly gravitational barrier.
			The barrier gives infinite flight and allows levitating from the ground.
			It also slows down falls and pushes enemies away from you.
			Press the Adjust Gravity key to deactivate levitation.
			'''
	}

	GravitationalAnomaly: {
		DisplayName: Gravitational Anomaly
		Tooltip:
			'''
			An anomaly found in space and around powerful space distortions.
			Slightly modifies gravity.
			'''
	}

	GravityGlobe: {
		DisplayName: Controlled Anomaly
		Tooltip:
			'''
			An anomaly in a globe that gives full control of it.
			Right click to use New Star "Super Nova", spending {0} mana.
			Adds {1} Spell Card cooldown to the player.
			'''
	}

	ChristmasGlobe: {
		DisplayName: Christmas Globe
		Tooltip:
			'''
			A globe filled with so much cheer and joy that allows control of gravity.
			Right click to use Package "Super Present", spending {0} mana.
			Adds {1} Spell Card cooldown to the player.
			'''
	}

	ThrillEngine: {
		DisplayName: Thrill Engine
		Tooltip:
			'''
			A strange machine that enables the use of flashbombs.
			Charge a flashbomb by passing near a projectile and obtaining thrill.
			Lose all thrill once the flashbomb is used.
			Some items may have a different type of flashbomb.
			'''
	}

	FireTray: {
		DisplayName: Fire Tray
		Tooltip:
			'''
			Increases all damage by {0}%.
			Uses 16 spirits to power up attacks.
			Powered up attacks are always critical with additional critical damage and 
			inflict shadowflame.
			Projectiles will release spirit flames upon collision, while swinging weapons 
			will release spirits when swung.
			Cooldown of 3 seconds if a swinging weapon is powered up, 6 seconds if a 
			projectile is powered up.
			'''
	}

	LumenDisc: {
		DisplayName: Light Shell
		Tooltip:
			'''
			A hard shell made of some unknown material.
			Summons a disco ball that shoots light at nearby enemies.
			'''
	}

	LumenDiscFragment: {
		DisplayName: Shell Fragment
		Tooltip: A piece of a round object that warps light around it.
	}

	HarujionDebugTool: {
		DisplayName: Harujion Debug Tool
		Tooltip: ""
	}

	HarujionDebugTool2: {
		DisplayName: Harujion Debug Tool2
		Tooltip: ""
	}

	BarrierSupport: {
		DisplayName: Tome of barriers Vol.2
		Tooltip:
			'''
			A book that details more complex ways of using barriers 
			to teleport.
			Teleports enemy projectiles to the exit barrier.
			Right click to lock on to an enemy and teleport friendly 
			projectiles to the exit barrier.
			'''
	}

	FairyGun: {
		DisplayName: Small Gun
		Tooltip:
			'''
			Shoots a burst of three bullets.
			Why is a fairy carrying this?
			'''
	}

	FairySword: {
		DisplayName: Small Sword
		Tooltip: ""
	}

	FairyWand: {
		DisplayName: Small Wand
		Tooltip: Shoots bullets in three directions.
	}

	PowerRodFan: {
		DisplayName: Power Rod Bat
		Tooltip:
			'''
			A strange bat made of paper.
			Not great for hitting, but has great magical properties.
			Right click to switch between a minion mode and a sentry mode.
			'''
	}

	SenriPriestHeadpiece: {
		DisplayName: Senri Priest Hat
		Tooltip:
			'''
			A hat used by the Senri priest.
			The use of it's symbol brings fear upon the hearts of 
			men, though not so much on monsters.
			Increased damage by {0}%.
			Using a weapon will shoot an additional projectile 
			depending on the used boss ofuda.
			'''
	}

	BossOfuda: {
		DisplayName: Boss Ofuda
		Tooltip:
			'''
			An ofuda obtained by defeating a boss.
			Used to change the attack of the user when using the 
			{$SenriPriestHeadpiece.DisplayName}.
			'''
	}

	EyelessTsubaHat: {
		DisplayName: Big Hat
		Tooltip:
			'''
			A stylish black hat.
			It could attract something when nearby an opening to 
			the curtain of awakening.
			'''
	}

	TsubaHat: {
		DisplayName: Big Hat
		Tooltip:
			'''
			A stylish black hat.
			This one has an ominous eye in it.
			It could attract something when nearby an opening to 
			the curtain of awakening.
			'''
	}

	BullseyeMedal: {
		DisplayName: Bullseye Medal
		Tooltip:
			'''
			Awarded to excellent gunman.
			Increased ranged crit chance by {0}% and crit damage by {1}%.
			'''
	}

	MarksmanshipMedal: {
		DisplayName: Marksmanship Medal
		Tooltip:
			'''
			Proof of skill, only for the best.
			Increased ranged damage by {0}%, crit chance by {1}% 
			and crit damage by {2}%.
			Enemies release projectiles when hit by a critical ranged 
			attack, dealing 60% of the original damage.
			'''
	}

	BeginnerBarrier: {
		DisplayName: Tome of barriers Vol.1
		Tooltip:
			'''
			A book detailing the basics of a barrier.
			Gives the player a beginner barrier, which increases defense 
			while it's active.
			'''
	}

	HomunculusWeapon: {
		DisplayName: Vessel Blade
		Tooltip:
			'''
			A blade that creates body doubles of the user to fight.
			Right click to use Dharma Power "Myōken of Heaven's Blessings".
			Adds {0} Spell Card cooldown to the player.
			'''
	}

	BodyDoubleDye: {
		DisplayName: Body Double Dye
		Tooltip:
			'''
			A dye used to simplify the process of making the 
			Vessel Blade's projectiles.
			Was not meant to be found, but can be equipped.
			'''
	}

	HaniwaPerson: {
		DisplayName: Haniwa Duplicator
		Tooltip:
			'''
			Proof of your artistic mastery.
			Create a duplicate of yourself to fight for you.
			Takes up all the summon slots and increases it's damage.
			'''
	}

	HaniwaDye: {
		DisplayName: Haniwa Dye
		Tooltip: ""
	}

	HaniwaCreationTools: {
		DisplayName: Haniwa Creation Tools
		Tooltip:
			'''
			Tools for someone whose art surpassed divinity.
			Summons a haniwa clone of yourself and two haniwa cannons.
			Right click to summon the Super Haniwa.
			Adds {0} Spell Card cooldown to the player.
			'''
	}
}

