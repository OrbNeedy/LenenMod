Dialogue: {
	CurtainOfAwakening: {
		Chat: There is a crack in space that makes you want to put your hand in it.
		Awaken: Awaken
		Failed: You get in, but nothing happens.
	}
}

Fairy: {
	Small: {
		Mono: Small Monochrome Fairy
		Slash: Small Sword Fairy
		Magic: Small Magic Fairy
		Shot: Small Gun Fairy
	}
}

Bestiary: {
	CurtainOfAwakening: A mysterious portal to somewhere.
	SmallFairy: A small fairy who's always looking for conflict, despite being weak on their own, they have many friends with many different talents they can call. It's normally found in the surface, scouting the ground from the sky or wandering aimlessly.
}

Buffs: {
	Kurovirus: {
		DisplayName: Retrovirus
		Description: Something is messing with your DNA.
	}

	BarrierBuff: {
		DisplayName: Super Barrier
		Description:
			'''
			Increases all barrier regeneration by 50%.
			"Heals as much as kissin' it better."
			'''
	}

	BarrierBuff2: {
		DisplayName: Mega Barrier
		Description:
			'''
			Increases all barrier regeneration by 100%.
			"Mooooore poooooower!"
			'''
	}

	BarrierBuff3: {
		DisplayName: Hyper Barrier
		Description:
			'''
			Increases all barrier regeneration by 150%.
			"It's super regeneration!"
			'''
	}

	HaniwaCannonBuff: {
		DisplayName: Haniwa Artillery Support Fire
		Description: You're getting support from a Special Haniwa Artillery Unit.
	}

	HarujionAbsorb: {
		DisplayName: Soul Siphon
		Description:
			'''
			Your soul is being absorbed by a nearby Harujion.
			It will get stronger as you get closer, but the spirits you have collected 
			will decrease it's effect.
			'''
	}

	ResurrectionCooldown: {
		DisplayName: Neonatal
		Description:
			'''
			You have been reborn, and can't resurrect again.
			You are protected by a weak barrier that recovers fast.
			'''
	}

	LumenBallBuff: {
		DisplayName: Lumen Ball
		Description:
			'''
			A disco ball protects you.
			There might be something inside of it.
			'''
	}

	InkBirdMinionBuff: {
		DisplayName: Ink Bird
		Description: A bird made of ink will fight for you.
	}

	ArmorMode: {
		DisplayName: Armor Mode
		Description: Defense and damage reduction greatly increased.
	}

	HaniwaCloneBuff: {
		DisplayName: Haniwa Duplication
		Description: Your own duplicate will fight for you.
	}

	HaniwaCommander: {
		DisplayName: Haniwa Commander
		Description: The Haniwa special forces will fight for you.
	}
}

BarrierStats:
	'''
	This barrier can take up to {0} hits, needs {1} seconds to 
	begin recovering, {2} seconds to recover from a single hit, and 
	{3} seconds to fully recover from being broken.
	'''
HarujionGeneration: Growing a youkai flower.
SoulDescriptions.Reserve: It's storing {0} spirits.

MemoryDescriptions: {
	Trace: Trace: The knives will go back to their original spot after a while.
	Reproduction:
		'''
		Reproduction: The knives will leave more knives as they travel that 
		stay in place.
		'''
	Override: Override: The knives will ignore tiles and deal damage faster.
}

Death: {
	Denied: You were resurrected by the power of the Harujion.
	BigMistake: "{0} made a big mistake."
	Harujion: "{0}'s soul became plant food."
	RNA: "{0}'s DNA was scrambled beyond repair."
}

