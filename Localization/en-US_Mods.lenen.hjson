Configs: {
	GameplayConfig: {
		DisplayName: Gameplay Config

		Headers: {
			Harujion: Disable Harujion
			HarujionHardMode: Harujion Hard mode
		}

		HarujionAllowed: {
			Label: Harujion Allowed
			Tooltip:
				'''
				Turn off to disable all gameplay effects related to the Harujion.
				This will not destroy any existing Harujion tile or disable the 
				Harujion accessory from dropping.
				'''
		}

		HarujionHardMode: {
			Label: Harujion Hard Mode
			Tooltip:
				'''
				Turn on to enable the old Harujion absorption.
				Damage dealt to the player by the Harujion will increase by 400%, 
				damage dealt to other NPCs will increase by 200%, range and max 
				range will be doubled, and the amount of tiles it is allowed to 
				change on every attempt will be doubled.
				'''
		}
	}
}

