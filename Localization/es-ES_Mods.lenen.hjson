		HarujionAllowed: {
			Label: Harujion Permitido
			Tooltip:
				'''
				Desactivar para deshabilitar todos los efectos de Gameplay 
				relacionados al Harujion.
				Esto no va a destruir ningún bloque de Harujion existente o 
				deshabilitar el accesorio de Harujion.
				'''
		}

		HarujionHardMode: {
			Label: Modo dificil de Harujion
			Tooltip:
				'''
				Encender para habilitar la absorción de Harujion antigua.
				El daño causado al jugador por el Harujion aumenta en 400%, el 
				daño causado a otros NPCs aumenta en 200%, el rango y rango 
				maximo se duplicarán, y la cantidad de bloques que puede 
				reemplazar en cada intento se duplicará.
				'''
		}
	}
}

