Bestiary: {
	CurtainOfAwakening: Un portal misterioso a algún lado.
	SmallFairy: Un hada pequeña que siempre busca conflicto. A pesar de ser debil por su cuenta, tiene varios amigos con muchos talentos diferentes que puede llamar. Normalmente se encuentra en la superficie, revisando la tierra desde el cielo o vagando sin rumbo.
}

Buffs: {
	Kurovirus: {
		DisplayName: Retrovirus
		Description: Algo está molestando tu ADN.
	}

	BarrierBuff: {
		DisplayName: Super Barrera
		Description:
			'''
			Aumenta toda la regeneración de barrera en 50%.
			"Sana tanto como un beso"
			'''
	}

	BarrierBuff2: {
		DisplayName: Mega Barrier
		Description:
			'''
			Aumenta toda la regeneración de barrera en 100%.
			"¡Maaaaas podeeeeeer!"
			'''
	}

	BarrierBuff3: {
		DisplayName: Hiper Barrera
		Description:
			'''
			Aumenta toda la regeneración de barrera en 150%.
			"¡Es super regeneración!"
			'''
	}

	HaniwaCannonBuff: {
		DisplayName: Fuego de soporte de Haniwa de Artillery
		Description: Estás recibiendo apoyo de una Unidad Especial de Artillería Haniwa.
	}

	HarujionAbsorb: {
		DisplayName: Alma drenada
		Description:
			'''
			Tu alma está siendo absorbida por un Harujion cercano.
			Se volverá más fuerte mientras más cerca estés, pero los espiritus que has 
			recolectado reducirán su efecto.
			'''
	}

	ResurrectionCooldown: {
		DisplayName: Neonatál
		Description:
			'''
			Has renacido, y no puedes resucitar otra vez.
			Estás siendo protegido por una barrera debil que se recupera 
			rápido.
			'''
	}

	LumenBallBuff: {
		DisplayName: Bola Lumen
		Description:
			'''
			Una bola disco te proteje.
			Puede que haya algo adentro de ella.
			'''
	}

	InkBirdMinionBuff: {
		DisplayName: Ave de Tinta
		Description: Un ave hecha de tinta peleará por ti.
	}

	ArmorMode: {
		DisplayName: Modo de Armadura
		Description: Defensa y reducción de daño aumentadas.
	}

	HaniwaCloneBuff: {
		DisplayName: Duplicación Haniwa
		Description: Tu propio duplicado luchará por ti.
